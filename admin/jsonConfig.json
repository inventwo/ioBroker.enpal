{
	"i18n": true,
	"type": "panel",
	"items": {
		"_info": {
            "type": "header",
            "text": "ENPAL InfluxDB Configuration",
            "size": 3
        },
		"influx_url": {
			"type": "text",
			"label": "influx_url",
			"newLine": true,
			"default": "http://localhost:8086",
			"xs": 12,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"influx_token": {
			"type": "password",
			"label": "influx_token",
			"newLine": true,
			"xs": 12,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"influx_org": {
			"type": "text",
			"label": "influx_org",
			"newLine": true,
			"xs": 12,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"influx_bucket": {
			"type": "text",
			"label": "influx_bucket",
			"newLine": true,
			"xs": 12,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"interval_ms": {
			"type": "number",
			"label": "interval_ms",
			"newLine": true,
			"default": 60000,
			"min": 5000,
			"xs": 12,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		}
	}
}